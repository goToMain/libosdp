@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Crypto dependency block composed at configure time. Empty when libosdp
# was built against the bundled tinyaes backend (no external dep).
@LIBOSDP_FIND_DEPENDENCY_BLOCK@

include("${CMAKE_CURRENT_LIST_DIR}/libosdpTargets.cmake")

# Default consumer-facing alias. Resolves to the shared library when
# available, falling back to the static library. CMake 3.18 added ALIAS
# support for IMPORTED targets; on older CMake we fall back to an
# INTERFACE IMPORTED wrapper that achieves the same thing.
if(NOT TARGET libosdp::libosdp)
  if(CMAKE_VERSION VERSION_GREATER_EQUAL 3.18)
    if(TARGET libosdp::osdp)
      add_library(libosdp::libosdp ALIAS libosdp::osdp)
    elseif(TARGET libosdp::osdpstatic)
      add_library(libosdp::libosdp ALIAS libosdp::osdpstatic)
    endif()
  else()
    add_library(libosdp::libosdp INTERFACE IMPORTED)
    if(TARGET libosdp::osdp)
      set_target_properties(libosdp::libosdp PROPERTIES
        INTERFACE_LINK_LIBRARIES libosdp::osdp)
    elseif(TARGET libosdp::osdpstatic)
      set_target_properties(libosdp::libosdp PROPERTIES
        INTERFACE_LINK_LIBRARIES libosdp::osdpstatic)
    endif()
  endif()
endif()
