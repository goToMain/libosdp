prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
includedir=${prefix}/include
libdir=${exec_prefix}/@LIBOSDP_PC_LIBDIR_REL@

Name: @PROJECT_NAME@
Description: @PROJECT_DESCRIPTION@
URL: @PROJECT_URL@
Version: @PROJECT_VERSION@
Requires.private: @LIBOSDP_PC_REQUIRES_PRIVATE@
Libs: -L${libdir} -l@LIB_TARGET@
Cflags: -I${includedir}/libosdp
